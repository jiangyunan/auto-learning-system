llm:
  base_url: http://localhost:11434/v1
  api_key: ollama
  model: llama3
  temperature: 0.7

input:
  recursive: true
  max_depth: 2

output:
  format: obsidian
  path: ./vault/
  filename_template: "{title}.md"

features:
  chinese_notes: true

chunker:
  target_tokens: 1500
  overlap_chars: 200

cache:
  enabled: true
  db_path: ./data/cache.db

# URL递归采集配置 (可选)
crawl:
  patterns:
    - "*.md"
    - "*/docs/*"
  max_depth: 3
